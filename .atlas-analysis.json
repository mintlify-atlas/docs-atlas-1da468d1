  "keyFeatures": [
    "Durable execution with automatic state persistence",
    "Workflow orchestration using generators and promises",
    "Activity execution with retry and error handling",
    "Child workflow support for complex hierarchies",
    "Signals, queries, and updates for workflow interaction",
    "Timers and await conditions for time-based logic",
    "Saga pattern for distributed transactions",
    "Workflow versioning for safe evolution",
    "Webhook integration for external triggers",
    "Laravel Queue integration for async execution",
    "Waterline monitoring dashboard",
    "Event-driven architecture"
